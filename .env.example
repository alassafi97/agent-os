# ============================================
# Agent OS — API Keys Configuration
# ============================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Each agent lists which keys it needs.
# You only need keys for agents you plan to use.
# ============================================

# --- Research & Scraping ---
# Exa: Semantic search for companies, people, and content (used by Pluto, Atlas, Themis, Felix)
# Get your key: https://dashboard.exa.ai/api-keys
EXA_API_KEY=

# Firecrawl: Website scraping — converts any URL to clean markdown (used by Pluto, Atlas, Themis)
# Get your key: https://firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=

# Apify: LinkedIn profile/company scraping (used by Pluto, Atlas, Felix, Artemis)
# Get your key: https://console.apify.com/account/integrations
APIFY_API_KEY=

# --- Lead Generation ---
# Apollo: Company/contact discovery with structured filters — best data quality (used by Felix)
# Get your key: https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=

# --- Email & Outreach ---
# Instantly: Cold email sending (used by Emilio)
# Get your key: https://app.instantly.ai/settings/integrations
INSTANTLY_API_KEY=

# --- LinkedIn ---
# HeyReach: LinkedIn automation (used by Leonardo)
# Get your key: https://app.heyreach.io/settings
HEYREACH_API_KEY=

# --- Enrichment ---
# Hunter: Email finder & verifier (used by Felix, Emilio)
# Get your key: https://hunter.io/api-keys
HUNTER_API_KEY=

# --- Transcription ---
# Deepgram: Audio transcription — transcribes reel audio to extract spoken hooks (used by Picasso)
# Get your key: https://console.deepgram.com/signup (free $200 credits)
DEEPGRAM_API_KEY=

# --- General ---
# (Add any additional API keys your custom agents need below)
