# Agent OS — Environment Variables
# Copy this file to .env and fill in your keys

# Required for all agents
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required for Pluto (Advanced mode) and Artemis
# Get from: https://exa.ai
EXA_API_KEY=your-exa-key-here

# Required for Artemis (LinkedIn scraping)
# Get from: https://apify.com
APIFY_API_KEY=your-apify-key-here

# Optional: for Emilio to send emails directly
# Get from: your email provider's API settings
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
